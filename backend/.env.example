# ApiPulse 环境变量配置
# 复制为 .env 后按需修改

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=120.0

# max_tokens 按任务类型细粒度控制（不同任务输出长度不同）
OPENAI_MAX_TOKENS_DOC=3000       # 文档生成
OPENAI_MAX_TOKENS_ASSERTS=3000   # 断言生成
OPENAI_MAX_TOKENS_SCENARIO=4096  # 场景生成
OPENAI_MAX_TOKENS_DIFF_EVAL=2048 # 差异评估（输出 JSON 较短）

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=api_quality

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_QUARANTINE=har-quarantine

# CORS（逗号分隔，* 表示允许所有来源）
CORS_ORIGINS=*

# 应用环境
APP_ENV=development
LOG_LEVEL=INFO
